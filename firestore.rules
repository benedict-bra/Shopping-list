rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles + all subcollections ──────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /prefs/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /recipes/{recipeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Lists + all subcollections ───────────────────────────────────────────
    match /lists/{listId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      allow update: if request.auth != null
        && (
          request.auth.uid in resource.data.memberIds
          || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberIds', 'memberNames'])
        );

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberIds;

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;

      // Items — accessible to all list members
      match /items/{itemId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.memberIds;
      }

      // Categories — accessible to all list members (shared ordering)
      match /categories/{catId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.memberIds;
      }

      // Stores — accessible to all list members
      match /stores/{storeId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.memberIds;
      }

      // Prices — shared between all list members
      match /prices/{priceKey} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.memberIds;
      }
    }

    // ── Invites ─────────────────────────────────────────────────────────────
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Legacy collections (kept for migration reads) ────────────────────────
    match /categories/{uid}/cats/{catId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /stores/{uid}/stores/{storeId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
