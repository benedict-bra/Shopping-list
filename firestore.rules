// =============================================================================
// FIRESTORE SECURITY RULES
// =============================================================================
// Deploy these in Firebase Console → Firestore → Rules
// or via: firebase deploy --only firestore:rules
//
// Rules summary:
//   - Users can only read/write their own profile
//   - Lists are readable/writable only by members
//   - List items inherit list membership
//   - Categories and stores are private per user
//   - Invites are readable by anyone signed in, writable only by list members
// =============================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ───────────────────────────────────────────────────────
    // Each user can only read and write their own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // User preferences (display settings, prices) sit under /users/{uid}/prefs/
      match /prefs/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Lists ───────────────────────────────────────────────────────────────
    // A list is readable/writable if the signed-in user is in memberIds.
    match /lists/{listId} {
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      // Only authenticated users can create a list, and they must add themselves as a member.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberIds;

      // Only the owner can delete a list.
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;

      // ── Items (subcollection) ─────────────────────────────────────────────
      // Items inherit list membership — if you're a member of the list, you
      // can read and write all items in it.
      match /items/{itemId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.memberIds;
      }
    }

    // ── Invites ─────────────────────────────────────────────────────────────
    // Any signed-in user can read an invite (to accept it).
    // Only signed-in users can create invites (the list member check happens in app code).
    // Invites are deleted after use.
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Categories ──────────────────────────────────────────────────────────
    // Categories are private — each user owns their own category set.
    match /categories/{uid}/cats/{catId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Stores ──────────────────────────────────────────────────────────────
    // Stores are private per user.
    match /stores/{uid}/stores/{storeId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
